{
  "name": "SkillSwapRequest",
  "type": "object",
  "properties": {
    "from_email": {
      "type": "string",
      "description": "Requester email"
    },
    "from_name": {
      "type": "string"
    },
    "to_email": {
      "type": "string",
      "description": "Recipient email"
    },
    "to_name": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "description": "Request message"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "declined"
      ],
      "default": "pending"
    }
  },
  "required": [
    "from_email",
    "to_email"
  ]
}